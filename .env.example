# .env.example
# Copy this file to .env and modify values as needed

# Server Settings
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# Paths
MATERIALS_DIR=./study_materials
CACHE_DIR=./cache

# Document Processing
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_SNIPPETS=3

# Search Settings
DEFAULT_TOP_K=5
MAX_TOP_K=20

# Ranking
IMPORTANCE_THRESHOLD=0.5

# Logging
LOG_LEVEL=INFO

# Optional: Database (for future use)
# DATABASE_URL=postgresql://user:password@localhost:5432/study_materials

# Optional: Vector DB (for future use)
# FAISS_INDEX_PATH=./index/faiss.index
# EMBEDDING_MODEL=all-MiniLM-L6-v2
